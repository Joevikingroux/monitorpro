# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=

# ── Admin Account (created on first startup) ──────────────────
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ── Domain / URL ──────────────────────────────────────────────
DOMAIN=

# ── Email Alerts (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Telegram Alerts ───────────────────────────────────────────
# Create a bot via @BotFather, get the token
TELEGRAM_TOKEN=
# Get your chat ID via @userinfobot
TELEGRAM_CHAT_ID=

# ── Data Retention ────────────────────────────────────────────
# Days to keep metric history before pruning
RETENTION_DAYS=90

# ── Alert Engine ──────────────────────────────────────────────
# How often the alert engine checks thresholds (seconds)
ALERT_CHECK_INTERVAL=30
