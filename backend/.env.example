# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_strong_password_here

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_a_random_hex_string

# ── Admin Account (created on first startup) ──────────────────
ADMIN_EMAIL=admin@numbers10.co.za
ADMIN_PASSWORD=admin123

# ── Domain / URL ──────────────────────────────────────────────
DASHBOARD_URL=https://localhost:8443
CORS_ORIGINS=https://localhost:8443

# ── Email Alerts (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@numbers10.co.za
# Who receives the alert emails (your email address)
ALERT_EMAIL=joe@numbers10.co.za

# ── Telegram Alerts ───────────────────────────────────────────
# Create a bot via @BotFather, get the token
TELEGRAM_TOKEN=
# Get your chat ID via @userinfobot
TELEGRAM_CHAT_ID=

# ── Data Retention ────────────────────────────────────────────
# Days to keep metric history before pruning
RETENTION_DAYS=90

# ── Alert Engine ──────────────────────────────────────────────
# How often the alert engine checks thresholds (seconds)
ALERT_CHECK_INTERVAL=30
