# ── Database ──────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ── Admin Account (created on first startup) ──────────────────
ADMIN_EMAIL=joe@numbers10.co.za
ADMIN_PASSWORD=ChangeMe123!

# ── Domain / URL ──────────────────────────────────────────────
DOMAIN=YOUR-VPS-IP-OR-DOMAIN

# ── Email Alerts (SMTP) ───────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@numbers10.co.za
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=PCMonitor <alerts@numbers10.co.za>

# ── Telegram Alerts ───────────────────────────────────────────
# Create a bot via @BotFather, get the token
TELEGRAM_TOKEN=
# Get your chat ID via @userinfobot
TELEGRAM_CHAT_ID=

# ── Data Retention ────────────────────────────────────────────
# Days to keep metric history before pruning
RETENTION_DAYS=90

# ── Alert Engine ──────────────────────────────────────────────
# How often the alert engine checks thresholds (seconds)
ALERT_CHECK_INTERVAL=30
